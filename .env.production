# ============================================
# 🌐 网络配置
# ============================================
# 代理前缀
VITE_APP_BASE_API = '/prod-api'
# 项目名称
VITE_APP_TITLE=vue3-element-admin
# SSE 端点（使用 VITE_APP_BASE_API 前缀自动拼接）
# 示例：/prod-api/api/v1/sse/connect 

# ============================================
# 🎛️ 功能开关
# ============================================
# 多租户（需与后端 app.tenant.enabled 保持一致）
VITE_APP_TENANT_ENABLED=true

